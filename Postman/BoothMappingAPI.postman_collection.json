		{
			"name": "Location Updates",
			"item": [
				{
					"name": "Update Booth Location - Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"",
									"pm.test(\"Success is true\", function () {",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"pm.test(\"Booth is now mapped\", function () {",
									"    pm.expect(jsonData.data.isMapped).to.equal('true');",
									"    pm.expect(jsonData.data.latitude).to.exist;",
									"    pm.expect(jsonData.data.longitude).to.exist;",
									"    pm.expect(jsonData.data.mappedBy).to.exist;",
									"    pm.expect(jsonData.data.mappedDate).to.exist;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
