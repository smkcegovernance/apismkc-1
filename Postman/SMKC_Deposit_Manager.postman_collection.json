{
  "info": {
    "name": "SMKC Deposit Management System",
    "_postman_id": "deposit-manager-collection-001",
    "description": "Complete Postman collection for SMKC Deposit Manager with HMAC-SHA256 authentication. Both AccountController and BankController verified working.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// =================================",
          "// CLIENT SIGNATURE GENERATION",
          "// FIXED: Properly resolve variables before signing",
          "// =================================",
          "",
          "// Generate Unix timestamp (seconds)",
          "const timestamp = Math.floor(Date.now() / 1000).toString();",
          "",
          "// Request body (empty for GET)",
          "let requestBody = '';",
          "if (pm.request && pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
          "  requestBody = pm.request.body.raw;",
          "}",
          "",
          "// Credentials",
          "const apiKey = pm.variables.get('apiKey') || pm.environment.get('apiKey');",
          "const secretKey = pm.variables.get('secretKey') || pm.environment.get('secretKey');",
          "",
          "// Method",
          "const httpMethod = pm.request.method.toUpperCase();",
          "",
          "// IMPORTANT: Get the RESOLVED URL (with variables replaced)",
          "// Build the URL manually to ensure variables are resolved",
          "let requestUri = pm.request.url.getPath();",
          "",
          "// Add query parameters if present",
          "const queryParams = pm.request.url.query.all();",
          "if (queryParams && queryParams.length > 0) {",
          "  const queryString = queryParams",
          "    .filter(param => !param.disabled)",
          "    .map(param => param.key + '=' + param.value)",
          "    .join('&');",
          "  if (queryString) {",
          "    requestUri += '?' + queryString;",
          "  }",
          "}",
          "",
          "// DETAILED DEBUG LOGGING",
          "console.log('=== CLIENT SIGNATURE GENERATION ===');",
          "console.log('HTTP Method:', httpMethod);",
          "console.log('Request URI:', requestUri);",
          "console.log('Request Body:', requestBody || '(empty)');",
          "console.log('Timestamp:', timestamp);",
          "console.log('API Key:', apiKey ? apiKey.substring(0, 10) + '...' : 'MISSING');",
          "",
          "// Check for unresolved variables BEFORE signing",
          "if (requestUri.includes('{{') || requestUri.includes('}}')) {",
          "  console.error('⚠️ CRITICAL ERROR: Unresolved variable detected in URI!');",
          "  console.error('URI contains:', requestUri);",
          "  console.error('This will cause signature mismatch!');",
          "  console.error('Make sure environment is selected and variables are set!');",
          "}",
          "",
          "// String to sign: METHOD + URI + BODY + TIMESTAMP + APIKEY",
          "const stringToSign = httpMethod + requestUri + requestBody + timestamp + apiKey;",
          "console.log('String to Sign:', stringToSign.substring(0, 200) + '...');",
          "console.log('String to Sign Length:', stringToSign.length);",
          "",
          "// Calculate HMAC-SHA256 signature",
          "const signature = CryptoJS.HmacSHA256(stringToSign, secretKey).toString(CryptoJS.enc.Base64);",
          "console.log('Generated Signature:', signature);",
          "console.log('=====================================');",
          "",
          "// Set variables",
          "pm.variables.set('timestamp', timestamp);",
          "pm.variables.set('signature', signature);"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:57031" },
    { "key": "apiKey", "value": "TEST_API_KEY_12345678901234567890123456789012" },
    { "key": "secretKey", "value": "TEST_SECRET_KEY_67890ABCDEFGHIJ1234567890" },
    { "key": "requirementId", "value": "REQ0000000003" },
    { "key": "bankId", "value": "BANK-001" },
    { "key": "timestamp", "value": "" },
    { "key": "signature", "value": "" }
  ],
  "item": [
