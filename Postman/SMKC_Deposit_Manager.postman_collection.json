            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"BANK001\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","login"]
            },
            "description": "Unified login for all user types (Bank, Account, Commissioner). Returns ROLE_ID: 1=Commissioner, 2=Account, 3=Bank."
          }
        },
