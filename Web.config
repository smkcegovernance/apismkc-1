<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="oracle.manageddataaccess.client"
             type="OracleInternal.Common.ODPMSectionHandler, Oracle.ManagedDataAccess, Version=4.122.1.0, Culture=neutral, PublicKeyToken=89b483f429c47342" />
  </configSections>

  <appSettings>
    <add key="AllowedIPs" value="127.0.0.1,::1,192.168.40.27,192.168.40.0/24" />
    <add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
    <add key="webpages:Enabled" value="false" />

    <add key="Sms_User" value="sangli-corpotp" />
    <add key="Sms_Password" value="Smkc@1998" />
    <add key="Sms_SenderId" value="SMKCRP" />
    <add key="Sms_Channel" value="Trans" />
    <add key="Sms_DefaultRoute" value="62" />
    <add key="Sms_DefaultPeId" value="1001211556856033653" />
    <add key="Sms_MaxNumbersPerRequest" value="100" />
    <add key="Sms_DCS_Unicode" value="8" />
    <add key="Sms_DefaultDltTemplateId" value="1007370196521127500" />

    <!-- API authentication keys -->
    <!-- For production, replace these with strong unique keys -->
    <!-- Booth Mapping Production Keys (Generate unique keys for production) -->
    <add key="EnableApiKeyAuthentication" value="false" />
    <add key="ApiKey" value="CHANGE_ME_API_KEY" />
    <add key="ApiSecret" value="CHANGE_ME_SECRET" />
    <add key="Auth_TimestampSkewMinutes" value="5" />

    <!-- Google Drive Configuration for Silent Authentication (Service Account) -->
    <!-- Service Account = No browser popup, No user interaction required -->
    <add key="GoogleDrive_UseServiceAccount" value="true" />
    <add key="GoogleDrive_CredentialsPath" value="GoogleDrive\service-account-credentials.json" />
    <add key="GoogleDrive_ApplicationName" value="SMKC Deposit Manager API" />
    <!-- Optional: for My Drive targets, impersonate a real Workspace user with quota -->
    <!-- Requires domain-wide delegation enabled on the service account -->
    <add key="GoogleDrive_DelegatedUserEmail" value="" />
    <!-- Optional alternative for personal Gmail/My Drive: OAuth user token flow -->
    <!-- When all 3 are set, API uses user OAuth instead of service-account token flow -->
    <add key="GoogleDrive_OAuthClientId" value="CHANGE_ME_GOOGLE_OAUTH_CLIENT_ID" />
    <add key="GoogleDrive_OAuthClientSecret" value="CHANGE_ME_GOOGLE_OAUTH_CLIENT_SECRET" />
    <add key="GoogleDrive_OAuthRefreshToken" value="" />
    
    <!-- IMPORTANT: Service Accounts don't have storage quota -->
    <!-- You MUST share a folder from a real user's Google Drive with the service account -->
    <!-- Steps:
         1. Create a folder in your Google Drive (e.g., "SMKC_API_Storage")
         2. Right-click → Share → Add the service account email as Editor
            (Email is in service-account-credentials.json: "client_email")
         3. Copy the folder ID from the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
         4. Paste the folder ID below
    -->
    <add key="GoogleDrive_SharedFolderId" value="1Jb--DaiXGdshrfVzrADqLLyRLEtezgLp" />

    <!-- Storage Configuration for Consent Documents -->
    <!-- Use "ftp" for FTP storage or "network" for network share storage -->
    <add key="Storage_Type" value="ftp" />

    <!-- Network share configuration - using admin share (c$) with subdirectory -->
    <!-- Direct access to: \\192.168.40.47\c$\inetpub\ftproot\BankConsents -->
    <add key="Network_Server" value="192.168.40.47" />
    <add key="Network_Share" value="c$\inetpub\ftproot\BankConsents" />
    
    <!-- Alternative: Use direct local path if API is running on same server -->
    <!-- <add key="Network_LocalPath" value="C:\inetpub\ftproot\BankConsents" /> -->

    <!-- Credentials for accessing network share -->
    <add key="Ftp_User" value="administrator" />
    <add key="Ftp_Password" value="smkc@1234" />

    <!-- Legacy FTP configuration (kept for backward compatibility) -->
    <add key="Ftp_Host" value="192.168.40.47" />
    <add key="Ftp_Port" value="21" />
    <add key="Ftp_BasePath" value="/BankConsents" />

    <!-- WCWC disability registration storage -->
    <add key="Wcwc_Ftp_BasePath" value="/DisabilityRegistrations" />
    <add key="Wcwc_Network_Share" value="c$\inetpub\ftproot\DisabilityRegistrations" />
  </appSettings>

  <connectionStrings>
    <add name="OracleDb"
         providerName="Oracle.ManagedDataAccess.Client"
         connectionString="User Id=ws;Password=ws;Data Source=//SMKC-SCAN:1521/hcldb;Pooling=true;Min Pool Size=1;Max Pool Size=100;Connection Timeout=60;Incr Pool Size=5;Decr Pool Size=2;Connection Lifetime=300;Validate Connection=true" />

    <add name="OracleDbWebsite"
         providerName="Oracle.ManagedDataAccess.Client"
         connectionString="User Id=website;Password=website;Data Source=//SMKC-SCAN:1521/hcldb;Pooling=true;Min Pool Size=1;Max Pool Size=100;Connection Timeout=60;Incr Pool Size=5;Decr Pool Size=2;Connection Lifetime=300;Validate Connection=true" />

    <add name="OracleDbUlberp"
         providerName="Oracle.ManagedDataAccess.Client"
         connectionString="User Id=ulberp;Password=ulberp;Data Source=//SMKC-SCAN:1521/hcldb;Pooling=true;Min Pool Size=1;Max Pool Size=100;Connection Timeout=60;Incr Pool Size=5;Decr Pool Size=2;Connection Lifetime=300;Validate Connection=true" />

    <add name="OracleDbAbas"
         providerName="Oracle.ManagedDataAccess.Client"
         connectionString="User Id=abas;Password=abas;Data Source=//SMKC-SCAN:1521/hcldb;Pooling=true;Min Pool Size=1;Max Pool Size=100;Connection Timeout=60;Incr Pool Size=5;Decr Pool Size=2;Connection Lifetime=300;Validate Connection=true" />

        <add name="OracleDbWcwc"
          providerName="Oracle.ManagedDataAccess.Client"
              connectionString="User Id=WCWC;Password=WCWC;Data Source=//SMKC-SCAN:1521/hcldb;Pooling=true;Min Pool Size=1;Max Pool Size=100;Connection Timeout=60;Incr Pool Size=5;Decr Pool Size=2;Connection Lifetime=300;Validate Connection=true" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" maxRequestLength="10240" />
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8" culture="en-US" uiCulture="en-US" />
    <customErrors mode="Off" />
    <authentication mode="None" />
    <pages controlRenderingCompatibilityVersion="4.0" />
  </system.web>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <modules>
      <remove name="WebDAVModule" />
      <remove name="UrlRoutingModule-4.0" />
      <add name="UrlRoutingModule-4.0" type="System.Web.Routing.UrlRoutingModule" preCondition="" />
    </modules>
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <remove name="WebDAV" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0" 
           path="*." 
           verb="GET,HEAD,POST,DEBUG,PUT,DELETE,PATCH,OPTIONS" 
           type="System.Web.Handlers.TransferRequestHandler" 
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Cors" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.3.0" newVersion="5.2.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Http" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.3.0" newVersion="5.2.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Net.Http.Formatting" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.2.3.0" newVersion="5.2.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <publisherPolicy apply="no" />
        <assemblyIdentity name="Oracle.ManagedDataAccess" publicKeyToken="89b483f429c47342" culture="neutral" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

  <system.data>
    <DbProviderFactories>
      <remove invariant="Oracle.ManagedDataAccess.Client" />
      <add name="ODP.NET, Managed Driver"
           invariant="Oracle.ManagedDataAccess.Client"
           description="Oracle Data Provider for .NET, Managed Driver"
           type="Oracle.ManagedDataAccess.Client.OracleClientFactory, Oracle.ManagedDataAccess, Version=4.122.1.0, Culture=neutral, PublicKeyToken=89b483f429c47342" />
    </DbProviderFactories>
  </system.data>

  <oracle.manageddataaccess.client>
    <version number="*">
      <dataSources>
        <dataSource alias="SampleDataSource"
                    descriptor="(DESCRIPTION=(ADDRESS=(PROTOCOL=tcp)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL))) " />
      </dataSources>
    </version>
  </oracle.manageddataaccess.client>
</configuration>